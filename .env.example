# Runtime
APP_ENV=development
DRY_RUN=true
DAILY_SEND_LIMIT=2
DATABASE_PATH=data/outreach.sqlite3
LOG_LEVEL=INFO

# Daily scheduler
SCHEDULE_TIME=12:20
TIMEZONE=America/Denver

# Denver Odor Pros sender details
GMAIL_SENDER=denverodorpros@gmail.com
BUSINESS_NAME=Denver Odor Pros LLC
CONTACT_NAME=Max
BUSINESS_EMAIL=denverodorpros@gmail.com
BUSINESS_WEBSITE=www.denverodorpros.com
BUSINESS_PHONE=(303)882-2989
BUSINESS_ADDRESS=[business mailing address]
LOGO_PATH=assets/denver-odor-pros-logo.png

# Search provider. Brave is recommended because Google Custom Search JSON API is closed to new customers.
SEARCH_PROVIDER=brave
BRAVE_SEARCH_API_KEY=

# Optional legacy Google Programmable Search API settings.
# Only use if you are an existing Custom Search JSON API customer.
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Gmail OAuth files. See README for setup.
GMAIL_CLIENT_SECRET_FILE=secrets/gmail_client_secret.json
GMAIL_TOKEN_FILE=secrets/gmail_token.json

# Compliance controls
# Comma-separated domains that this automation may fetch with Requests/BeautifulSoup
# after robots.txt allows it. Keep this narrow and confirm each site's Terms first.
ALLOWED_FETCH_DOMAINS=remax.com,kw.com,coldwellbanker.com,compass.com,century21.com,bhhs.com,exprealty.com,homesmart.com,windermere.com,realtyonegroup.com,intero.com,longandfoster.com

# Comma-separated domains to never fetch or contact from.
BLOCKED_DOMAINS=zillow.com,trulia.com,realtor.com,redfin.com

# Optional: override the default search query.
SEARCH_QUERY=("active listing" OR "for sale") ("listing agent" OR "brokerage") (email OR mailto OR "@") ("Denver CO" OR "Castle Rock CO" OR "Parker CO" OR "Aurora CO" OR "Colorado") -"Denver NC"
